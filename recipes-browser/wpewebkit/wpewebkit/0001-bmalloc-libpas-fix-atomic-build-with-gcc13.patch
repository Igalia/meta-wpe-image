Date: Thu, 2 Jul 2026 11:13:57 +0200
Subject: [PATCH] bmalloc/libpas: avoid C stdatomic in C++ build on GCC13/Yocto

* Source/bmalloc/libpas/src/libpas/pas_utils.h:
---
 Source/bmalloc/libpas/src/libpas/pas_utils.h | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/Source/bmalloc/libpas/src/libpas/pas_utils.h b/Source/bmalloc/libpas/src/libpas/pas_utils.h
index 433b26f0ad3e..d0173f53c100 100644
--- a/Source/bmalloc/libpas/src/libpas/pas_utils.h
+++ b/Source/bmalloc/libpas/src/libpas/pas_utils.h
@@ -42,7 +42,15 @@
 #endif
 
 #include <limits.h>
+#if defined(__cplusplus)
+/* Use C++ atomics in C++ translation units to avoid toolchain/header mode
+ * mismatches around C11 _Atomic (seen with GCC13 cross builds in Yocto). */
+#include <atomic>
+#define PAS_ATOMIC(T) std::atomic<T>
+#else
 #include <stdatomic.h>
+#define PAS_ATOMIC(T) _Atomic(T)
+#endif
 #include <stdbool.h>
 #include <stdint.h>
 #include <string.h>
-- 
2.43.0

